# =============================================================
# .gitignore — PT. Kusuma Samudera Berkah
# =============================================================
# Panduan:
#   ✅ File yang PERLU di-commit: source code, config.example, migrations
#   ❌ File yang JANGAN di-commit: .env, database, uploads, generated files

# ─── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribusi & packaging
*.egg
*.egg-info/
dist/
build/
*.whl
*.tar.gz
MANIFEST

# ─── Testing & Coverage ───────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.lcov
nosetests.xml
test-results/

# ─── Database ─────────────────────────────────────────────────
# Jangan commit file database — gunakan migration untuk schema
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# PostgreSQL dump
*.sql.gz
*.dump

# ─── Environment & Secrets ────────────────────────────────────
# JANGAN pernah commit file .env yang berisi secrets!
.env
.env.*
!.env.example
!env.example

# ─── Frontend ─────────────────────────────────────────────────
node_modules/
dist/
build/
.vite/
*.local

# ─── Logs & Temporary files ───────────────────────────────────
*.log
*.log.*
logs/
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ─── PDF & Media (generated files) ───────────────────────────
# File yang di-generate server, jangan di-commit
*.pdf
*.xlsx
*.xls
*.csv

# Upload files (user-uploaded content)
uploads/
static/uploads/
media/
/backend/uploads/
/backend/static/uploads/

# Script migrasi one-off (bukan Alembic)
migrasi_*.py
*_migration_temp.py

# ─── OS Files ─────────────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ─── IDE & Editor ─────────────────────────────────────────────
# VS Code — commit settings.json & extensions.json agar tim bisa share config
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains (PyCharm, WebStorm, dll.)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Emacs
*.swp
*.swo
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ─── Docker ───────────────────────────────────────────────────
# Volumes lokal Docker (jika mount ke folder project)
docker-volumes/
.docker/

# ─── Alembic ──────────────────────────────────────────────────
# File migrations DI-COMMIT — hanya abaikan cache-nya
migrations/__pycache__/
migrations/versions/__pycache__/

# ─── Backup & Temp files ──────────────────────────────────────
*.backup
*.old
*.orig
.cache/
tmp/
temp/

# ─── ReportLab / WeasyPrint temporary ─────────────────────────
/backend/app/generated/
/backend/app/temp/

# ─── Frontend generated assets ────────────────────────────────
# Hasil 'npm run build' — tidak perlu di-commit, di-build saat deploy
frontend/dist/

# ─── Package lock (opsional — uncommit baris ini jika ingin commit lock) ─
# package-lock.json
# yarn.lock

# ─── Mobile (Capacitor & Android/iOS Keys) ──────────────────────
frontend/android/
*.jks
*.keystore
key.properties
signing.properties
google-services.json
GoogleService-Info.plist

# ─── SSL/TLS Certificates & Keys ──────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx

# ─── Native Android App ───────────────────────────────────────
/Android/
